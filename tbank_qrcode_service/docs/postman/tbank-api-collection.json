{
  "info": {
    "name": "TBank QR Code Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Init Payment and Get QR",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/sbp/init-and-qr?userId={{user_id}}&amount={{amount}}",
          "query": [
            {"key": "userId", "value": "{{user_id}}"},
            {"key": "amount", "value": "{{amount}}"}
          ]
        }
      }
    },
    {
      "name": "Init Payment - Missing UserId",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/sbp/init-and-qr?amount={{amount}}",
          "query": [
            {"key": "amount", "value": "{{amount}}"}
          ]
        }
      }
    },
    {
      "name": "Init Payment - Zero Amount",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/sbp/init-and-qr?userId={{user_id}}&amount=0",
          "query": [
            {"key": "userId", "value": "{{user_id}}"},
            {"key": "amount", "value": "0"}
          ]
        }
      }
    },
    {
      "name": "Init Payment - Negative Amount",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/sbp/init-and-qr?userId={{user_id}}&amount=-100",
          "query": [
            {"key": "userId", "value": "{{user_id}}"},
            {"key": "amount", "value": "-100"}
          ]
        }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/actuator/health"
      }
    },
    {
      "name": "WebSocket - Subscribe Payment",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/ws",
        "description": "WebSocket connection. Subscribe: SUBSCRIBE /topic/payment/{{order_id}}"
      }
    }
  ],
  "variable": [
    {"key": "base_url", "value": "http://208.92.226.223:8080"},
    {"key": "user_id", "value": "test_user_001"},
    {"key": "amount", "value": "100.50"},
    {"key": "order_id", "value": "order-xxxxxxxx-xxxx"}
  ]
}
