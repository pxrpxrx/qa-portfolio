    {
      "parameters": {
        "jsCode": "const processedItems = [];\n\n// !!! ВАЖНО: Замените этот плейсхолдер на реальный публичный API Key !!!\nconst API_KEY_PLACEHOLDER = 'KgKtCV5I01hpvbKhOQV8WK6yqqnG9M1SZAuf5PoEnSdB20aoznCsmgOO4ZYg7rJBG5X7xuUOsFzOv7RXisg'; \n// Устанавливаем разумное время ожидания (в миллисекундах)\nconst RECV_WINDOW = 5000; \n\n// --- НАСТРОЙКИ BINGX API ---\n// Выносим константы URL за пределы цикла, чтобы избежать ReferenceError\nconst urlPath = '/openApi/wallets/v1/capital/config/getall';\nconst baseDomain = 'https://open-api.bingx.com'; \nconst method = 'GET';\n\nfor (const item of items) {\n    const timestamp = item.json.data?.serverTime || Math.floor(Date.now());\n    const apiKey = item.json.apiKey || API_KEY_PLACEHOLDER; \n    \n    // --- НАСТРОЙКИ BINGX API ---\n    const urlPath = '/openApi/wallets/v1/capital/config/getall';\n    const baseDomain = 'https://open-api.bingx.com';\n    // ...\n    \n    // --- 2. СБОРКА ПАРАМЕТРОВ (без сортировки) ---\n    \n    // Параметры для нашего запроса:\n    // 1. recvWindow\n    // 2. timestamp\n    // (Поскольку наш запрос не содержит symbol, нам нужны только эти два)\n    \n    const parameters = {\n        recvWindow: RECV_WINDOW,\n        timestamp: timestamp\n    };\n    \n    // ПОРЯДОК: Формируем строку вручную в ожидаемом порядке: recvWindow, timestamp\n    const signatureString = `recvWindow=${parameters.recvWindow}&timestamp=${parameters.timestamp}`;\n    \n    // --- 3. СОХРАНЕНИЕ ДАННЫХ ДЛЯ ДАЛЬНЕЙШИХ УЗЛОВ ---\n    \n    item.json.signatureString = signatureString; // Отправляется Worker'у\n    item.json.bingxBaseUrl = `${baseDomain}${urlPath}`;\n    \n    // Сохраняем все данные для финального HTTP-запроса\n    item.json.timestamp = timestamp;\n    item.json.apiKey = apiKey;\n    item.json.recvWindow = RECV_WINDOW; \n    \n    processedItems.push(item);\n}\n\nreturn processedItems;"
      },
