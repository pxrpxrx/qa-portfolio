    {
      "parameters": {
        "jsCode": "// Этот код предполагает, что на вход подается массив из двух элементов:\n// Первый элемент - результат запроса к Cloudflare Worker\n// Второй элемент - результат запроса к Bybit\n// Важно убедиться, что узлы в вашем рабочем процессе подключены в правильном порядке.\n\nconst signatureData = items[0].json; // Данные с подписью\nconst bybitData = items[1].json; // Данные от Bybit\n\n// Объединяем два объекта в один, используя деструктуризацию\nconst mergedObject = {\n  ...signatureData,\n  ...bybitData\n};\n\n// Возвращаем объединенный объект в виде одного элемента массива\nreturn [{ json: mergedObject }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2208,
        112
      ],
      "id": "53f8c0c8-a2d1-4b9e-a8d5-fc2e4f62fcec",
      "name": "JOIN3"
    },
    {
      "parameters": {
        "jsCode": "const processedItems = [];\nconst exchangeName = 'BingX'; \n\n// Карта соответствия полных названий сетей (ключи) их стандартизированным сокращениям (значения)\nconst networkMapping = {\n    \"ARBITRUM\": \"ARB\",\n    \"ERC20\": \"ETH\",\n    \"TRC20\": \"TRX\",\n    \"AVAX-C\": \"AVAX\",\n    \"BEP20\": \"BSC\",\n    \"OPTIMISM\": \"OP\",\n    \"POLYGON\": \"MATIC\"\n};\n\nfunction standardizeNetwork(networkName) {\n    // 1. Приводим входящее имя к верхнему регистру для соответствия ключам\n    const upperName = networkName.toUpperCase();\n    \n    // 2. Ищем в карте соответствия\n    // Если найдено, возвращаем стандартизированное сокращение.\n    // Если не найдено, возвращаем исходное (уже верхнее) имя.\n    const standardized = networkMapping[upperName] || upperName;\n\n    // Гарантируем, что результат всегда в верхнем регистре\n    return standardized.toUpperCase();\n}\n\n\nfor (const item of items) {\n    const currencyInfo = item.json;\n\n    if (currencyInfo && currencyInfo.networkList && currencyInfo.networkList.length > 0) {\n        \n        // Монету приводим к верхнему регистру для единообразия\n        const coinName = (currencyInfo.coin || currencyInfo.name || '').toUpperCase();\n        \n        for (const network of currencyInfo.networkList) {\n            \n            // --- СТАНДАРТИЗАЦИЯ ИМЕНИ СЕТИ ---\n            const standardizedChainName = standardizeNetwork(network.network);\n            \n            const withdrawEnabled = network.withdrawEnable;\n            \n            processedItems.push({\n                json: {\n                    coin_name: coinName,\n                    \n                    // Используем стандартизированное имя\n                    chain: standardizedChainName, \n                    \n                    withdraw_fee: network.withdrawFee,\n                    min_withdraw: network.withdrawMin,\n                    is_enabled: withdrawEnabled,\n                    \n                    // --- НОВОЕ ПОЛЕ: МИНИМАЛЬНЫЕ ПОДТВЕРЖДЕНИЯ ---\n                    min_confirm: network.minConfirm, \n                    \n                    exchange: exchangeName\n                }\n            });\n        }\n    }\n}\n\nreturn processedItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3152,
