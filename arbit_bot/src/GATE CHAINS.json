    {
      "parameters": {
        "jsCode": "// Код для преобразования currency_pair\nfor (const item of items) {\n  const currencyPair = item.json.currency_pair;\n\n  if (currencyPair) {\n    // Убираем символ подчеркивания\n    const newCurrencyPair = currencyPair.replace('_', '');\n    \n    // Обновляем значение в элементе\n    item.json.currency_pair = newCurrencyPair;\n  }\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        -16
      ],
      "id": "27ef10b8-a157-4b10-a8de-610302e42c4d",
      "name": "Code"
    },
    {
      "parameters": {
        "options": {
          "reset": false
        }
      },
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        544,
        -16
      ],
      "id": "0d6ba146-2bc1-411c-9b3f-d7f03c4c3275",
      "name": "Loop Over Items1"
    },
    {
      "parameters": {
        "jsCode": "const mergedItems = [];\nconst coinItems = [];\nlet latestServerTime = null;\n\n// 1. Разделяем входящие данные на два типа: монеты и время\nfor (const item of items) {\n  if (item.json && item.json.coin_name) {\n    coinItems.push(item.json);\n  } else if (item.json && item.json.server_time) {\n    // Находим самое свежее время\n    if (!latestServerTime || item.json.server_time > latestServerTime) {\n      latestServerTime = item.json.server_time;\n    }\n  }\n}\n\n// 2. Если у нас есть и монеты, и время, объединяем их\nif (coinItems.length > 0 && latestServerTime !== null) {\n  for (const coin of coinItems) {\n    const mergedItem = {\n      ...coin,\n      server_time: latestServerTime\n    };\n    mergedItems.push({ json: mergedItem });\n  }\n}\n\nreturn mergedItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1232,
        -16
      ],
      "id": "0f0ecec3-af01-4129-8e37-159d9d32fdf6",
      "name": "JOIN2"
    },
    {
      "parameters": {
        "jsCode": "const recvWindow = 60;\n\nfor (const item of items) {\n  const serverTime = $input.first().json.server_time;\n  const coinSymbol = $input.first().json.coin_name;\n  const apiKey = '056f8de44c3f7f6c0195cda9f59d210a';\n\n  const urlPath = '/api/v4/spot/currencies/' + coinSymbol;\n  const method = 'GET';\n  \n  // Убедитесь, что sign_payload - это одна строка\n  const signPayload = `timestamp:${serverTime}\\nmethod:${method}\\nurl:${urlPath}\\nbody:\\n`;\n  \n  item.json.sign_payload = signPayload.replace(/\\n/g, \"\\\\n\");\n\n  item.json.serverTime = serverTime;\n  item.json.apiKey = apiKey;\n  item.json.gateUrl = `https://api.gateio.ws${urlPath}`;\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1456,
        112
