      "name": "Split Out8"
    },
    {
      "parameters": {
        "jsCode": "const uniqueSymbols = new Set();\n\nfor (const item of items) {\n  if (item.json && item.json.currency_pair) {\n    let symbol = item.json.currency_pair;\n    // Удаляем из символа пары USDT, USDC, BTC и т.д.\n    symbol = symbol.replace(/USDT|USDC|BTC|BUSD|ETH|BNB|EUR|USD|DAI|PLN|TRY|TUSD/i, '');\n    uniqueSymbols.add(symbol);\n  }\n}\n\n// Конвертируем Set в массив объектов\nconst finalSymbols = [...uniqueSymbols].map(symbol => ({ coin_name: symbol }));\n\nreturn [{ json: { allCoins: finalSymbols } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        144,
        -16
      ],
