    {
      "parameters": {
        "jsCode": "const processedItems = [];\n\n// Обрабатываем каждый элемент, который пришел с предыдущего узла\nfor (const item of items) {\n  const currencyInfo = item.json;\n\n  // Убедимся, что у нас есть данные и массив сетей\n  if (currencyInfo && currencyInfo.chains && currencyInfo.chains.length > 0) {\n    // Проходим по каждой сети в массиве\n    for (const network of currencyInfo.chains) {\n      // Создаем объект с нужными полями\n      processedItems.push({\n        json: {\n          coin_name: currencyInfo.currency,\n          chain: network.name,\n          exchange: 'Gate.io'\n        }\n      });\n    }\n  }\n}\n\nreturn processedItems;"
      },
